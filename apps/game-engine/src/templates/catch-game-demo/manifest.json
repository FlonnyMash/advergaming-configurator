{
  "id": "catch-game-demo",
  "version": "1.0.0",
  "author": "Imported",
  "previewUrl": "/previews/catch-game-demo.png",
  "status": "published",
  "label": "Catch Game Demo",
  "description": "Data-driven catch game — entity arrays drive spawning, scoring, and player movement.",
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "themeColor": {
        "type": "string",
        "default": "#ff8040",
        "x-control": {
          "type": "color",
          "label": "Background color",
          "targetCategory": "branding",
          "targetPath": "themeColor",
          "surface": "both"
        }
      },
      "durationSeconds": {
        "type": "number",
        "default": 27,
        "minimum": 5,
        "maximum": 600,
        "x-control": {
          "type": "slider",
          "label": "Round duration (seconds)",
          "targetCategory": "system",
          "targetPath": "durationSeconds",
          "surface": "studio",
          "step": 1
        }
      },
      "itemSpawnRateMs": {
        "type": "number",
        "default": 300,
        "minimum": 200,
        "maximum": 10000,
        "x-control": {
          "type": "slider",
          "label": "Item spawn interval (ms)",
          "targetCategory": "system",
          "targetPath": "itemSpawnRateMs",
          "surface": "studio",
          "step": 50
        }
      },
      "catchableItems": {
        "type": "array",
        "default": [
          {
            "id": "default-good",
            "assetUrl": "/template-assets/catch-game-demo/assets/bad-1.png",
            "scoreValue": 10,
            "dropSpeed": 200,
            "spawnWeight": 1
          }
        ],
        "x-control": {
          "type": "entityArray",
          "label": "Catchable items",
          "itemLabel": "Catchable item",
          "targetCategory": "system",
          "targetPath": "catchableItems",
          "surface": "studio",
          "defaultItem": {
            "id": "catchable-new",
            "assetUrl": "",
            "scoreValue": 10,
            "dropSpeed": 200,
            "spawnWeight": 1
          },
          "itemFields": [
            {
              "key": "id",
              "label": "Entity ID",
              "type": "text"
            },
            {
              "key": "assetUrl",
              "label": "Sprite",
              "type": "image"
            },
            {
              "key": "scoreValue",
              "label": "Score value",
              "type": "slider",
              "min": 1,
              "max": 100,
              "step": 1
            },
            {
              "key": "dropSpeed",
              "label": "Drop speed",
              "type": "slider",
              "min": 50,
              "max": 500,
              "step": 10
            },
            {
              "key": "spawnWeight",
              "label": "Spawn weight",
              "type": "slider",
              "min": 0,
              "max": 10,
              "step": 1
            }
          ]
        }
      },
      "hazardItems": {
        "type": "array",
        "default": [
          {
            "id": "default-hazard",
            "assetUrl": "/template-assets/catch-game-demo/assets/bad-1.png",
            "scoreValue": -5,
            "dropSpeed": 280,
            "spawnWeight": 1
          }
        ],
        "x-control": {
          "type": "entityArray",
          "label": "Hazard items",
          "itemLabel": "Hazard item",
          "targetCategory": "system",
          "targetPath": "hazardItems",
          "surface": "studio",
          "defaultItem": {
            "id": "hazard-new",
            "assetUrl": "",
            "scoreValue": -5,
            "dropSpeed": 280,
            "spawnWeight": 1
          },
          "itemFields": [
            {
              "key": "id",
              "label": "Entity ID",
              "type": "text"
            },
            {
              "key": "assetUrl",
              "label": "Sprite",
              "type": "image"
            },
            {
              "key": "scoreValue",
              "label": "Penalty (negative)",
              "type": "slider",
              "min": -50,
              "max": -1,
              "step": 1
            },
            {
              "key": "dropSpeed",
              "label": "Drop speed",
              "type": "slider",
              "min": 50,
              "max": 500,
              "step": 10
            },
            {
              "key": "spawnWeight",
              "label": "Spawn weight",
              "type": "slider",
              "min": 0,
              "max": 10,
              "step": 1
            }
          ]
        }
      },
      "playerEntity": {
        "type": "object",
        "properties": {
          "assetUrl": {
            "type": "string",
            "default": "/template-assets/catch-game-demo/assets/player.png",
            "x-control": {
              "type": "image",
              "label": "Player sprite",
              "targetCategory": "branding",
              "targetPath": "playerEntity.assetUrl",
              "surface": "studio"
            }
          },
          "speed": {
            "type": "number",
            "default": 320,
            "minimum": 50,
            "maximum": 800,
            "x-control": {
              "type": "slider",
              "label": "Player speed",
              "targetCategory": "system",
              "targetPath": "playerEntity.speed",
              "surface": "studio",
              "step": 10
            }
          }
        }
      }
    }
  },
  "phaserScenes": [
    "CatchGameScene"
  ],
  "uiOverlayComponents": []
}
