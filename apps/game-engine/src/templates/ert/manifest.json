{
  "id": "ert",
  "version": "0.1.0",
  "author": "Mashed Games Studio",
  "previewUrl": "/previews/ert.svg",
  "status": "draft",
  "label": "ert",
  "description": "New game template scaffold. Edit mechanics in Studio or extend GameScene.ts.",
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "branding": {
        "type": "object",
        "properties": {
          "theme": {
            "type": "object",
            "properties": {
              "primaryColor": {
                "type": "string",
                "x-control": {
                  "type": "color",
                  "label": "Primary color",
                  "targetCategory": "branding",
                  "targetPath": "theme.primaryColor",
                  "surface": "both"
                },
                "default": "#6366f1"
              }
            }
          },
          "domOverlay": {
            "type": "object",
            "properties": {
              "startScreenTitle": {
                "type": "string",
                "x-control": {
                  "type": "text",
                  "label": "Start screen title",
                  "targetCategory": "branding",
                  "targetPath": "domOverlay.startScreenTitle",
                  "surface": "configurator",
                  "placeholder": "ert"
                },
                "default": "ert"
              }
            }
          }
        }
      },
      "system": {
        "type": "object",
        "properties": {
          "mechanics": {
            "type": "object",
            "properties": {
              "playerSpeed": {
                "type": "number",
                "x-control": {
                  "type": "slider",
                  "label": "Motion speed",
                  "targetCategory": "system",
                  "targetPath": "mechanics.playerSpeed",
                  "surface": "studio",
                  "step": 10
                },
                "default": 200,
                "minimum": 50,
                "maximum": 800
              }
            }
          },
          "physics": {
            "type": "object",
            "properties": {
              "gravity": {
                "type": "number",
                "x-control": {
                  "type": "slider",
                  "label": "Gravity",
                  "targetCategory": "system",
                  "targetPath": "physics.gravity.y",
                  "surface": "studio",
                  "step": 10
                },
                "default": 0,
                "minimum": -1000,
                "maximum": 1000
              }
            }
          }
        }
      }
    }
  },
  "phaserScenes": [
    "Ert"
  ],
  "uiOverlayComponents": []
}
