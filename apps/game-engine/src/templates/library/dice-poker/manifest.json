{
  "id": "dice-poker",
  "version": "1.0.0",
  "author": "Mashed Games",
  "previewUrl": "/previews/dice-poker.svg",
  "status": "production",
  "label": "Dice Poker",
  "description": "WebGL dice table with branded start screen.",
  "phaserScenes": ["DicePoker"],
  "uiOverlayComponents": ["StartScreen"],
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "branding": {
        "type": "object",
        "properties": {
          "theme": {
            "type": "object",
            "properties": {
              "primaryColor": {
                "type": "string",
                "default": "#6366f1",
                "x-control": {
                  "type": "color",
                  "label": "Primary color",
                  "targetCategory": "branding",
                  "targetPath": "theme.primaryColor",
                  "surface": "both"
                }
              }
            }
          },
          "domOverlay": {
            "type": "object",
            "properties": {
              "startScreenTitle": {
                "type": "string",
                "default": "Play Now",
                "x-control": {
                  "type": "text",
                  "label": "Start screen title",
                  "targetCategory": "branding",
                  "targetPath": "domOverlay.startScreenTitle",
                  "surface": "configurator",
                  "placeholder": "Play Now"
                }
              }
            }
          }
        }
      },
      "system": {
        "type": "object",
        "properties": {
          "mechanics": {
            "type": "object",
            "properties": {
              "playerSpeed": {
                "type": "number",
                "default": 200,
                "minimum": 50,
                "maximum": 400,
                "x-control": {
                  "type": "slider",
                  "label": "Player speed",
                  "targetCategory": "system",
                  "targetPath": "mechanics.playerSpeed",
                  "surface": "studio",
                  "step": 10
                }
              }
            }
          }
        }
      }
    }
  }
}
