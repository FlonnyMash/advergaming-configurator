{
  "name": "desktop",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "node ../../scripts/dev-desktop.mjs",
    "test:asset-ipc": "node --test asset-ipc-utils.test.js export-ipc-utils.test.js",
    "verify:asset-ipc-wiring": "node scripts/verify-asset-ipc-wiring.mjs",
    "verify:asset-ipc": "npm run test:asset-ipc && npm run verify:asset-ipc-wiring",
    "sync-branding": "node scripts/sync-installer-workspace.mjs && node scripts/sync-installer-branding.mjs",
    "prebuild": "node scripts/ensure-dist-writable.mjs && node scripts/sync-installer-workspace.mjs && node scripts/sync-installer-branding.mjs && node scripts/apply-nsis-install-overrides.mjs && node scripts/materialize-deps.mjs",
    "build:package": "pnpm run prebuild",
    "build": "pnpm run build:package",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "archiver": "^7.0.1",
    "archiver-utils": "^5.0.2",
    "async": "^3.2.4",
    "balanced-match": "^1.0.2",
    "brace-expansion": "^2.1.1",
    "builder-util-runtime": "^9.5.1",
    "debug": "^4.4.3",
    "electron-updater": "^6.3.9",
    "fs-extra": "^11.2.0",
    "get-port": "5.1.1",
    "graceful-fs": "^4.2.11",
    "js-yaml": "^4.1.1",
    "jsonfile": "^6.2.1",
    "lazy-val": "^1.0.5",
    "lodash.escaperegexp": "^4.1.2",
    "lodash.isequal": "^4.5.0",
    "minimatch": "^5.1.9",
    "ms": "^2.1.3",
    "readdir-glob": "^1.1.3",
    "sax": "^1.6.0",
    "semver": "^7.8.1",
    "tiny-typed-emitter": "^2.1.0",
    "universalify": "^2.0.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "adm-zip": "^0.5.17",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5"
  },
  "build": {
    "appId": "com.mashedgames.studio",
    "electronVersion": "31.7.7",
    "publish": null,
    "productName": "Mashed Games Studio",
    "icon": "icon.ico",
    "directories": {
      "output": "dist",
      "buildResources": "nsis"
    },
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "files": [
      "main.js",
      "preload.js",
      "asset-ipc-utils.js",
      "auth-ipc-utils.js",
      "license-ipc-utils.js",
      "export-ipc-utils.js",
      "flat-config-ipc-utils.js",
      "constants.js",
      "package.json",
      "splash.html",
      "splash-logo.png",
      "runtime-supabase.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../dashboard/.next/standalone",
        "to": "standalone",
        "filter": [
          "**/*",
          "!**/apps/game-engine/**"
        ]
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "publisherName": "${env.WIN_PUBLISHER_NAME}",
      "signingHashAlgorithms": [
        "sha256"
      ],
      "timeStampServer": "http://timestamp.digicert.com"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "en_US"
      ],
      "language": "1033",
      "multiLanguageInstaller": false,
      "displayLanguageSelector": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "menuCategory": "Mashed Games",
      "shortcutName": "Mashed Games Studio",
      "runAfterFinish": true,
      "artifactName": "MashedGames-Studio-Setup-${version}.${ext}",
      "uninstallDisplayName": "${productName}",
      "deleteAppDataOnUninstall": false,
      "include": "installer.nsh",
      "installerSidebar": "installerSidebar.bmp",
      "uninstallerSidebar": "uninstallerSidebar.bmp",
      "installerHeader": "installerHeader.bmp",
      "installerIcon": "installerIcon.ico",
      "uninstallerIcon": "uninstallerIcon.ico",
      "warningsAsErrors": true
    }
  }
}
