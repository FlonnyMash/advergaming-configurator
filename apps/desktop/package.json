{
  "name": "desktop",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "prebuild": "node scripts/ensure-dist-writable.mjs",
    "build": "electron-builder",
    "dist": "electron-builder"
  },
  "dependencies": {
    "builder-util-runtime": "^9.5.1",
    "debug": "^4.4.3",
    "electron-updater": "^6.3.9",
    "fs-extra": "^11.2.0",
    "get-port": "^7.1.0",
    "graceful-fs": "^4.2.11",
    "js-yaml": "^4.1.1",
    "jsonfile": "^6.2.1",
    "lazy-val": "^1.0.5",
    "lodash.escaperegexp": "^4.1.2",
    "lodash.isequal": "^4.5.0",
    "ms": "^2.1.3",
    "sax": "^1.6.0",
    "semver": "^7.8.1",
    "tiny-typed-emitter": "^2.1.0",
    "universalify": "^2.0.1"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.mashedgames.advergamingstudio",
    "productName": "Advergaming Studio",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "files": [
      "main.js",
      "package.json",
      {
        "from": "../dashboard/.next/standalone",
        "to": "standalone",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../dashboard/.next/static",
        "to": "standalone/apps/dashboard/.next/static",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../dashboard/public",
        "to": "standalone/apps/dashboard/public",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business"
    },
    "win": {
      "target": "nsis",
      "publisherName": "${env.WIN_PUBLISHER_NAME}",
      "signingHashAlgorithms": [
        "sha256"
      ],
      "timeStampServer": "http://timestamp.digicert.com"
    }
  }
}
