{
  "name": "mashedgames-studio",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "dev:studio": "pnpm exec cross-env NEXT_PUBLIC_ENABLE_STUDIO_MODE=true node scripts/run-dev.mjs",
    "dev:client": "pnpm exec cross-env NEXT_PUBLIC_ENABLE_STUDIO_MODE=false node scripts/run-dev.mjs",
    "dev:phase1": "concurrently --kill-others-on-fail --names PKG-SHARED,PKG-CONFIG,PKG-STUDIO --prefix-colors cyan,magenta,blue \"node ./node_modules/typescript/bin/tsc --project packages/shared/tsconfig.json --watch --noEmit --preserveWatchOutput\" \"node ./node_modules/typescript/bin/tsc --project packages/configurator-engine/tsconfig.json --watch --noEmit --preserveWatchOutput\" \"node ./node_modules/typescript/bin/tsc --project packages/studio-engine/tsconfig.json --watch --noEmit --preserveWatchOutput\"",
    "dev:phase2": "concurrently --kill-others-on-fail --names DASH,ENGINE --prefix-colors green,yellow \"node ./apps/dashboard/node_modules/next/dist/bin/next dev --hostname 127.0.0.1 --port 3000\" \"node ./apps/game-engine/node_modules/vite/bin/vite.js --host 127.0.0.1 --port 5173 --strictPort\"",
    "dev:phase3": "node scripts/dev-phase3.mjs",
    "dev:desktop": "node scripts/dev-desktop.mjs",
    "dev:desktop:studio": "pnpm exec cross-env NEXT_PUBLIC_ENABLE_STUDIO_MODE=true node scripts/run-dev.mjs",
    "dev:desktop:standalone": "pnpm --filter desktop dev",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "pnpm run build:pipeline",
    "build:clean": "rimraf \"apps/dashboard/.next\" \"apps/dashboard/out\" \"apps/game-engine/dist\" \"apps/desktop/dist\" \"apps/desktop/_staging\" \"apps/desktop/_staging_probe\" \".turbo\"",
    "build:packages": "pnpm --config.verifyDepsBeforeRun=false --filter @mashedgames/shared build && pnpm --config.verifyDepsBeforeRun=false --filter @mashedgames/configurator-engine build && pnpm --config.verifyDepsBeforeRun=false --filter @mashedgames/studio-engine build",
    "build:dashboard": "pnpm --config.verifyDepsBeforeRun=false --filter dashboard build:desktop",
    "build:dashboard:standalone": "pnpm --config.verifyDepsBeforeRun=false --filter dashboard build:desktop",
    "build:game-engine": "pnpm --config.verifyDepsBeforeRun=false --filter game-engine build",
    "build:assets:sync": "node scripts/copy-engine-to-dashboard.mjs && pnpm --config.verifyDepsBeforeRun=false --filter dashboard sync:standalone-assets",
    "build:engine": "pnpm run build:game-engine && node scripts/copy-engine-to-dashboard.mjs",
    "build:desktop:package": "pnpm --config.verifyDepsBeforeRun=false --filter desktop build:package",
    "build:pipeline": "pnpm run build:clean && pnpm run build:packages && pnpm run build:dashboard:standalone && pnpm run build:game-engine && pnpm run build:assets:sync && pnpm run build:desktop:package",
    "build:desktop": "pnpm run build:pipeline",
    "build:release:client": "node scripts/build-release.mjs client",
    "build:release:studio": "node scripts/build-release.mjs studio",
    "sync:brand": "pnpm --config.verifyDepsBeforeRun=false --filter desktop sync-branding"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@11.5.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.5.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "rimraf": "^6.1.0",
    "wait-on": "^8.0.5"
  }
}
