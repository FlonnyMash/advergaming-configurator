# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ─── Next.js build artifacts ─────────────────────────────────────────────────
.next/
out/
build/
apps/dashboard/.next/
apps/dashboard/.mashed-next-dev/
apps/dashboard/.local-workspace/

# ─── Vite / game-engine build outputs ────────────────────────────────────────
dist/
dist-ssr/
apps/game-engine/dist/

# ─── Electron desktop artifacts ──────────────────────────────────────────────
release/
apps/desktop/dist/
apps/desktop/release/
apps/desktop/out/
apps/desktop/_staging/
apps/desktop/_staging_probe/

# Next.js standalone output bundled into the Electron package (generated by
# build:dashboard:standalone + build:assets:sync — never commit this)
apps/desktop/standalone-bundle/

# Local runtime credential override written by the desktop build pipeline.
# Contains Supabase URL/anon key and must never be committed.
apps/desktop/runtime-supabase.json

# Electron binary download cache — electron-builder materialises downloaded
# Electron zips as SHA-256-named directories at the repo root.
.electron-*.zip
c94f2fc32e1fb05767f75322ea533eeb9828155f017ec184140930a3ec825e81/

# electron-builder installer side-car artefacts
*.blockmap

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
main-process-error.log

# ─── Environment / secrets ───────────────────────────────────────────────────
.env
.env.local
.env*.local
.env.development.local
.env.test.local
.env.production.local

# ─── TypeScript incremental build info ───────────────────────────────────────
*.tsbuildinfo

# ─── OS / editor noise ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
